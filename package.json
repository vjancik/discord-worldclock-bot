{
	"name": "discord-worldclock-bot",
	"module": "src/index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"start": "bun src/index.ts",
		"register-commands": "bun scripts/register-commands.ts",
		"deregister-commands": "bun scripts/deregister-commands.ts",
		"typecheck": "tsc --noEmit",
		"codecheck": "bunx biome check .",
		"codecheck:fix": "bunx biome check --fix .",
		"test": "bun test",
		"prod:up": "docker compose up --build -d",
		"prod:down": "docker compose down"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@types/bun": "^1.3.14",
		"@types/luxon": "^3.7.1"
	},
	"peerDependencies": {
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"chrono-node": "^2.9.1",
		"discord.js": "^14.26.4",
		"luxon": "^3.7.2",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3"
	}
}
